{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Top-level test classification (e.g., Hormones, Hematology)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "text"
    },
    "test_groups": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::test-group.test-group",
      "mappedBy": "category"
    }
  }
}
